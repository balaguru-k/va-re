{
  "name": "va-rewamp",
  "version": "1.0.0",
  "description": "VA Rewamp Application with Node.js, Express, React, and MySQL",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cd server && npm run dev",
    "client:dev": "cd client && npm start",
    "server:start": "cd server && npm start",
    "build": "cd client && npm run build",
    "client:build": "cd client && npm run build",
    "test": "npm run test:server && npm run test:client",
    "test:server": "cd server && npm test",
    "test:client": "cd client && npm test",
    "test:e2e": "cd e2e-tests && npm test",
    "migrate": "cd server && npm run migrate",
    "seed": "cd server && npm run seed",
    "setup": "npm install && cd server && npm install && cd ../client && npm install && cd ../e2e-tests && npm install"
  },
  "keywords": [
    "node",
    "express",
    "react",
    "mysql",
    "eloquent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@mui/x-date-pickers": "^8.22.1",
    "dayjs": "^1.11.19",
    "jspdf": "^4.2.1",
    "knex": "^3.1.0",
    "sharp": "^0.34.5",
    "sweetalert2": "^11.26.4",
    "xlsx": "^0.18.5"
  }
}
